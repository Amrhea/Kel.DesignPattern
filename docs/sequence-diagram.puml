@startuml Poker Hand Evaluator - Sequence Diagram

actor Main
participant "GameManager" as GM
participant "RuntimeSession" as Session
participant "BlindState" as Blind
participant "RoundManager" as RM
participant "PokerHandEvaluator" as PHE
participant "JokerCard" as Joker
participant "RewardCommand" as Cmd

Main -> GM: RunSession()
activate GM

Note over GM, Session: Initialize RuntimeSession (SmallBlindState active)

loop While session.ante == 1
    GM -> Session: get currentBlind details
    activate Session
    Session -> Blind: getName()
    activate Blind
    Blind --> Session: name
    deactivate Blind
    Session -> Blind: getTargetScore(ante)
    activate Blind
    Blind --> Session: targetScore
    deactivate Blind
    Session --> GM: name, target score
    deactivate Session

    alt Skip Blind
        GM -> Session: skipBlind()
        activate Session
        Session -> Blind: createSkipRewardCommand()
        activate Blind
        Blind --> Session: Command instance (queued)
        deactivate Blind
        Session -> Blind: nextState(ante)
        activate Blind
        Blind --> Session: Next BlindState
        deactivate Blind
        Note over Session: executePendingCommands("NextBlind")
        Session -> Cmd: execute(Session)
        activate Cmd
        Cmd --> Session: reward applied
        deactivate Cmd
        Session --> GM: execution & transition logs
        deactivate Session
    else Play Blind
        GM -> RM: RunRound(Session, BlindData)
        activate RM
        Note over RM: Draw/refill player Hand from shuffled Deck
        loop While round.status == PLAYING
            RM -> PHE: evaluate(playedHand)
            activate PHE
            PHE --> RM: HandEvaluation
            deactivate PHE

            Note over RM, Joker: JokerManager::ApplyJokers(persistentState, context)
            RM -> Joker: apply(context)
            activate Joker
            Joker --> RM: context modified
            deactivate Joker
        end
        RM --> GM: win/loss result
        deactivate RM

        GM -> Session: playBlind()
        activate Session
        Session -> Blind: nextState(ante)
        activate Blind
        Blind --> Session: Next BlindState
        deactivate Blind
        Note over Session: executePendingCommands("NextBlind")
        Session --> GM: transition logs
        deactivate Session
    end
end

deactivate GM

@enduml
